# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Nimble
NIMBLE_API_KEY=your-nimble-api-key
NIMBLE_API_BASE_URL=https://api.nimbleway.com

# Agent defaults
AGENT_MODEL=claude-sonnet-4-6
AGENT_MAX_TURNS=30
AGENT_POLL_INTERVAL_MS=5000

# Supermemory (optional — long-term memory)
SUPERMEMORY_ENABLED=false
SUPERMEMORY_API_KEY=
SUPERMEMORY_TAG_PREFIX=nimble_agents
# SUPERMEMORY_DEFAULT_TAGS=custom_tag_1,custom_tag_2
